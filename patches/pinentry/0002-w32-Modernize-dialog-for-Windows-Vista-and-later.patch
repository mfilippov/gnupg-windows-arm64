-    CTEXT           "", IDC_PINENT_ERR,    5, 90, 220, 12
-    DEFPUSHBUTTON   "O&K", IDOK,          50, 105, 85, 14
-    PUSHBUTTON      "&Cancel", IDCANCEL, 140, 105, 85, 14
+                                           7,  7,  32, 32
