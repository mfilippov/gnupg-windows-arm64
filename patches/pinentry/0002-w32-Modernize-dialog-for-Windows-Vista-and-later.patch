+    RTEXT           "", IDC_PINENT_PROMPT, 7, 59,  55,  8
+    EDITTEXT        IDC_PINENT_TEXT,      65, 56, 188, 14, ES_PASSWORD | ES_AUTOHSCROLL
+    CTEXT           "", IDC_PINENT_ERR,    7, 77, 246, 10
+    DEFPUSHBUTTON   "O&K", IDOK,          99, 94,  75, 14
